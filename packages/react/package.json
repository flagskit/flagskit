{
  "name": "@flagskit/react",
  "version": "0.1.0",
  "description": "React bindings for FlagsKit — Provider, hooks, and components.",
  "keywords": ["feature-flags", "react", "hooks", "typescript", "percentage-rollout", "no-backend", "feature-toggles"],
  "homepage": "https://github.com/flagskit/flagskit",
  "repository": { "type": "git", "url": "https://github.com/flagskit/flagskit" },
  "bugs": { "url": "https://github.com/flagskit/flagskit/issues" },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@flagskit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
